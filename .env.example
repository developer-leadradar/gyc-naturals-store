# ══════════════════════════════════════════════════════
# GYC Naturals — Environment Configuration Template
# ══════════════════════════════════════════════════════
# Copy to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.
# ══════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gyc_store
DB_USER=root
DB_PASS=

# ── Site ──────────────────────────────────────────────
SITE_NAME=GYC Naturals
SITE_URL=http://localhost/gyc-store
SITE_EMAIL=info@gycnaturals.com
ADMIN_EMAIL=admin@gycnaturals.com
SITE_PHONE=+234 800 000 0000
SITE_WHATSAPP=+2348000000000

# ── Paystack ──────────────────────────────────────────
# Dev: pk_test_ / sk_test_    Production: pk_live_ / sk_live_
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_CALLBACK_URL=http://localhost/gyc-store/api/paystack-verify.php

# ── Email: Resend (preferred) ─────────────────────────
# https://resend.com — free 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email: SMTP fallback ──────────────────────────────
SMTP_FROM_EMAIL=info@gycnaturals.com
SMTP_FROM_NAME=GYC Naturals
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=your@gmail.com
# Gmail: use an App Password — https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_16_char_app_password

# ── Supabase (optional — cloud media storage) ─────────
# Leave blank to use local /uploads/ directory
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=gyc-gallery

# ── Uploads (local dev) ───────────────────────────────
UPLOAD_PATH=C:/xampp/htdocs/gyc-store/uploads/
UPLOAD_URL=http://localhost/gyc-store/uploads/
