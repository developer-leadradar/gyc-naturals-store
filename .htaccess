Options -Indexes

# ── Block sensitive files ──────────────────────────────────
<FilesMatch "^(\.env.*|\.git.*|composer\.(json|lock)|package\.json|progress\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block utility/setup scripts from public access
<FilesMatch "^(install\.php|seed\.php|generate-icons\.php|deploy-checklist\.php|generate-assets\.php)$">
    Order allow,deny
    Allow from 127.0.0.1
    Allow from ::1
    Deny from all
</FilesMatch>

# Block direct access to includes/
<IfModule mod_rewrite.c>
RewriteEngine On

# Block direct PHP includes
RewriteRule ^includes/.*\.php$ - [F,L]

# Block vendor from web
RewriteRule ^vendor/.*$ - [F,L]

# Redirect to HTTPS in production (uncomment on live server)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Custom 404
ErrorDocument 404 /gyc-store/404.php

</IfModule>

# ── Security headers ──────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # Remove server signature
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ── Cache control ─────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Images
    ExpiresByType image/jpeg      "access plus 1 month"
    ExpiresByType image/png       "access plus 1 month"
    ExpiresByType image/webp      "access plus 1 month"
    ExpiresByType image/gif       "access plus 1 month"
    ExpiresByType image/svg+xml   "access plus 1 month"
    ExpiresByType image/x-icon    "access plus 1 year"
    # Fonts
    ExpiresByType font/woff2      "access plus 1 year"
    ExpiresByType font/woff       "access plus 1 year"
    # CSS/JS
    ExpiresByType text/css        "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    # Manifest
    ExpiresByType application/manifest+json "access plus 1 day"
    # Service Worker — never cache
    <Files "service-worker.js">
        ExpiresDefault "access plus 0 seconds"
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
    </Files>
</IfModule>

# ── Compression ───────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml application/manifest+json
</IfModule>

# ── PHP settings ──────────────────────────────────────────
<IfModule mod_php8.c>
    php_flag  display_errors    Off
    php_flag  log_errors        On
    php_value upload_max_filesize 10M
    php_value post_max_size       12M
    php_value max_execution_time  30
    php_value memory_limit        128M
    # Session security
    php_flag  session.cookie_httponly  On
    php_flag  session.use_strict_mode  On
    php_value session.gc_maxlifetime   3600
</IfModule>
<IfModule mod_php.c>
    php_flag  display_errors    Off
    php_flag  log_errors        On
    php_value upload_max_filesize 10M
    php_value post_max_size       12M
    php_value max_execution_time  30
    php_value memory_limit        128M
    php_flag  session.cookie_httponly  On
    php_flag  session.use_strict_mode  On
    php_value session.gc_maxlifetime   3600
</IfModule>

# ── Remove ETags (prevents info leakage) ─────────────────
FileETag None
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>

# ── Content-Type for manifest and SW ─────────────────────
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType application/manifest+json .json
</IfModule>
