{
  "version": 2,
  "name": "gyc-naturals",
  "builds": [
    {
      "src": "**/*.php",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/admin/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/manifest\\.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/service-worker\\.js",
      "dest": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/robots\\.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap\\.php",
      "dest": "/sitemap.php"
    },
    {
      "src": "/(.*)\\.php",
      "dest": "/$1.php"
    },
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "DB_DRIVER": "mysql",
    "DB_HOST": "@db_host",
    "DB_PORT": "3306",
    "DB_NAME": "@db_name",
    "DB_USER": "@db_user",
    "DB_PASS": "@db_pass",
    "SITE_NAME": "GYC Naturals",
    "SITE_URL": "https://gyc-naturals.vercel.app",
    "SITE_EMAIL": "info@gycnaturals.com",
    "ADMIN_EMAIL": "admin@gycnaturals.com",
    "SITE_PHONE": "+234 800 000 0000",
    "SITE_WHATSAPP": "+2348000000000",
    "PAYSTACK_PUBLIC_KEY": "@paystack_public_key",
    "PAYSTACK_SECRET_KEY": "@paystack_secret_key",
    "PAYSTACK_CALLBACK_URL": "https://gyc-naturals.vercel.app/api/paystack-verify.php",
    "RESEND_API_KEY": "@resend_api_key",
    "SMTP_FROM_EMAIL": "info@gycnaturals.com",
    "SMTP_FROM_NAME": "GYC Naturals",
    "UPLOAD_PATH": "/tmp/uploads/",
    "UPLOAD_URL": "https://gyc-naturals.vercel.app/uploads/"
  }
}
